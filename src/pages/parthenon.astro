---
import Layout from '../layouts/Layout.astro';
import ParthenonGallery from '../components/ParthenonGallery';
---

<Layout title="The Parthenon">
    <div class="py-10">
        <header class="mb-16 border-b border-neon-cyan/20 pb-8 relative">
            <div class="absolute inset-0 bg-gradient-to-r from-neon-cyan/5 to-transparent pointer-events-none -z-10"></div>
            <div class="flex items-center gap-4 mb-4">
                <span class="text-4xl drop-shadow-md">⚡</span>
                <h1 class="font-display text-4xl md:text-6xl font-black tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-white to-neon-cyan uppercase drop-shadow-[0_0_15px_rgba(0,240,255,0.3)]">
                    The Parthenon
                </h1>
            </div>
            <p class="font-body text-xl text-gray-300 max-w-3xl leading-relaxed drop-shadow-sm">
                The Showcase. A gallery of cyber-aesthetic generative art and successful agent workflows.
            </p>
        </header>

        <ParthenonGallery client:load />
    </div>
</Layout>
