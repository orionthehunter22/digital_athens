---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Parthenon">
    <div class="py-10">
        <header class="mb-16 border-b border-neon-cyan/20 pb-8 relative">
            <div class="absolute inset-0 bg-gradient-to-r from-neon-cyan/5 to-transparent pointer-events-none -z-10"></div>
            <div class="flex items-center gap-4 mb-4">
                <span class="text-4xl drop-shadow-md">⚡</span>
                <h1 class="font-display text-4xl md:text-6xl font-black tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-white to-neon-cyan uppercase drop-shadow-[0_0_15px_rgba(0,240,255,0.3)]">
                    The Parthenon
                </h1>
            </div>
            <p class="font-body text-xl text-gray-300 max-w-3xl leading-relaxed drop-shadow-sm">
                The Showcase. A gallery of cyber-aesthetic generative art and successful agent workflows.
            </p>
        </header>

        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="relative group aspect-square overflow-hidden border border-white/10 rounded cursor-pointer">
                <!-- Placeholder Image Effect -->
                <div class="absolute inset-0 bg-gradient-to-br from-neon-purple/20 to-neon-cyan/20 mix-blend-overlay z-10 group-hover:opacity-0 transition-opacity duration-500"></div>
                <div class="w-full h-full bg-[#111] flex items-center justify-center relative">
                    <!-- Tech grid background -->
                    <div class="absolute inset-0 bg-[linear-gradient(rgba(0,240,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,240,255,0.03)_1px,transparent_1px)] bg-[size:20px_20px]"></div>
                    <span class="text-6xl z-20 opacity-50 relative group-hover:scale-110 transition-transform duration-500">🎨</span>
                </div>
                
                <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black via-black/80 to-transparent translate-y-2 group-hover:translate-y-0 transition-transform duration-300 z-20">
                    <h3 class="font-display text-lg text-neon-cyan uppercase tracking-widest mb-1">Cyber-Athena</h3>
                    <p class="text-xs text-gray-400 font-body">Midjourney v6 - Neon Marble Series</p>
                </div>
            </div>
            
            <div class="relative group aspect-square overflow-hidden border border-white/10 rounded border-dashed border-neon-cyan/50 flex flex-col items-center justify-center bg-black/40 backdrop-blur-sm cursor-crosshair hover:bg-black/60 transition-colors duration-300">
                <span class="text-4xl mb-4 opacity-70">➕</span>
                <p class="font-display text-xs tracking-widest text-neon-cyan uppercase">Awaiting New Artifacts</p>
            </div>
        </section>
    </div>
</Layout>
