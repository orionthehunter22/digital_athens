---
import Layout from '../layouts/Layout.astro';
import SearchIsland from '../components/SearchIsland';
---

<Layout title="The Agora">
    <div class="py-10">
        <header class="mb-16 border-b border-neon-cyan/20 pb-8 relative">
            <div class="absolute inset-0 bg-gradient-to-r from-neon-cyan/5 to-transparent pointer-events-none -z-10"></div>
            <div class="flex items-center gap-4 mb-4">
                <span class="text-4xl drop-shadow-md">🏛️</span>
                <h1 class="font-display text-4xl md:text-6xl font-black tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-white to-neon-cyan uppercase drop-shadow-[0_0_15px_rgba(0,240,255,0.3)]">
                    The Agora
                </h1>
            </div>
            <p class="font-body text-xl text-gray-300 max-w-3xl mb-10 leading-relaxed drop-shadow-sm">
                The Marketplace of Ideas. Deep research, NotebookLM syntheses, and comprehensive guides into the agentic future.
            </p>
            
            <SearchIsland client:load />
        </header>

        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Placeholder for Research Content -->
            <div class="p-8 border border-white/10 bg-[#0a0a0a]/80 backdrop-blur-xl rounded-xl group hover:border-neon-cyan/50 hover:shadow-[0_0_30px_rgba(0,240,255,0.15)] transition-all duration-500 hover:-translate-y-1 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon-cyan/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                
                <div class="flex justify-between items-start mb-6">
                    <span class="text-[10px] font-display text-neon-cyan uppercase tracking-[0.2em] font-bold bg-neon-cyan/10 px-3 py-1 rounded-full border border-neon-cyan/20">Research Note</span>
                    <span class="text-xs text-gray-500 font-mono tracking-widest">OCT 24, 2025</span>
                </div>
                <h3 class="font-display text-2xl font-bold text-[#e0e0e0] mb-3 group-hover:text-neon-cyan transition-colors duration-300">
                    Local LLM Architectures
                </h3>
                <p class="text-gray-400 text-sm font-body mb-8 leading-relaxed">
                    A deep dive into running 7B models on M-series chips for decentralized reasoning and untethered AI experimentation.
                </p>
                <div class="flex items-center font-display text-xs uppercase tracking-widest text-[#e0e0e0] group-hover:text-neon-cyan transition-colors mt-auto font-bold">
                    Read Scroll <span class="ml-2 group-hover:translate-x-2 transition-transform duration-300">→</span>
                </div>
            </div>
            
            <div class="p-8 border border-white/5 bg-[#0a0a0a]/40 backdrop-blur-sm rounded-xl flex flex-col items-center justify-center text-center min-h-[250px] relative overflow-hidden">
                <div class="absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_10px,rgba(255,255,255,0.02)_10px,rgba(255,255,255,0.02)_20px)]"></div>
                <span class="text-4xl mb-4 opacity-30 grayscale blur-[1px]">📜</span>
                <p class="font-display text-xs tracking-[0.3em] font-bold text-gray-600 uppercase">More Scrolls Uploading...</p>
            </div>
        </section>
    </div>
</Layout>
