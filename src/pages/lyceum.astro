---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Lyceum">
    <div class="py-10">
        <header class="mb-16 border-b border-neon-cyan/20 pb-8">
            <div class="flex items-center gap-4 mb-4">
                <span class="text-4xl">🦉</span>
                <h1 class="font-display text-4xl md:text-5xl font-bold tracking-widest text-neon-cyan uppercase">
                    The Lyceum
                </h1>
            </div>
            <p class="font-body text-xl text-gray-400 max-w-3xl">
                AI Academy. High-signal tutorials, agent configurations, and lessons in the cyber-arts.
            </p>
        </header>

        <section class="max-w-4xl mx-auto space-y-8">
            <!-- Placeholder for Academy Tutorial -->
            <article class="relative pl-8 md:pl-0">
                <!-- Timeline Line -->
                <div class="hidden md:block absolute left-[120px] top-0 bottom-0 w-[1px] bg-neon-cyan/20"></div>
                
                <div class="md:flex gap-12 group cursor-pointer">
                    <!-- Date Column -->
                    <div class="hidden md:block w-24 flex-shrink-0 text-right pt-2 relative">
                        <!-- Timeline Dot -->
                        <div class="absolute right-[-29px] top-4 w-3 h-3 rounded-full bg-marble-dark border-2 border-neon-cyan group-hover:bg-neon-cyan group-hover:shadow-[0_0_10px_rgba(0,240,255,0.8)] transition-all duration-300 z-10"></div>
                        <span class="font-display text-xs text-neon-cyan uppercase tracking-widest">Lesson 01</span>
                    </div>

                    <!-- Content Card -->
                    <div class="flex-grow p-6 border border-white/10 bg-black/40 backdrop-blur-sm group-hover:border-neon-cyan/50 transition-colors duration-300 rounded relative">
                        <!-- Mobile Timeline Dot -->
                        <div class="md:hidden absolute left-[-37px] top-8 w-3 h-3 rounded-full bg-marble-dark border-2 border-neon-cyan group-hover:bg-neon-cyan transition-colors duration-300 z-10"></div>
                        
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-display text-2xl text-[#e0e0e0] group-hover:text-neon-cyan transition-colors duration-300">
                                Setting Up OpenClaw
                            </h3>
                            <span class="px-2 py-1 bg-neon-cyan/10 text-neon-cyan border border-neon-cyan/20 text-[10px] font-display uppercase tracking-widest rounded">Beginner</span>
                        </div>
                        <p class="text-gray-400 font-body mb-6">
                            A complete walkthrough on installing and configuring your first autonomous terminal agent.
                        </p>
                        
                        <div class="flex items-center gap-4 font-display text-xs text-gray-500 uppercase tracking-widest">
                            <span>15 Min Read</span>
                            <span>•</span>
                            <span class="text-[#e0e0e0] group-hover:text-neon-cyan transition-colors">Start Lesson →</span>
                        </div>
                    </div>
                </div>
            </article>
        </section>
    </div>
</Layout>
