---
import Layout from '../layouts/Layout.astro';

// District Data
const districts = [
    {
        title: "The Agora",
        desc: "The Marketplace of Ideas. Deep research & AI synthesis.",
        href: "/agora",
        icon: "🏛️",
        color: "group-hover:text-neon-cyan group-hover:border-neon-cyan",
        shadow: "group-hover:shadow-[0_0_30px_rgba(0,240,255,0.3)]"
    },
    {
        title: "The Lyceum",
        desc: "AI Academy. High-signal tutorials and agent configurations.",
        href: "/lyceum",
        icon: "🦉",
        color: "group-hover:text-neon-cyan group-hover:border-neon-cyan",
        shadow: "group-hover:shadow-[0_0_30px_rgba(0,240,255,0.3)]"
    },
    {
        title: "The Parthenon",
        desc: "The Showcase. A gallery of cyber-aesthetic generative art.",
        href: "/parthenon",
        icon: "⚡",
        color: "group-hover:text-neon-cyan group-hover:border-neon-cyan",
        shadow: "group-hover:shadow-[0_0_30px_rgba(0,240,255,0.3)]"
    },
    {
        title: "The Forge",
        desc: "Live Experiments. Automated logs and build-in-public raw data.",
        href: "/forge",
        icon: "⚒️",
        color: "group-hover:text-neon-purple group-hover:border-neon-purple",
        shadow: "group-hover:shadow-[0_0_30px_rgba(157,0,255,0.3)]"
    }
];
---

<Layout title="The Hub">
    <div class="flex flex-col items-center justify-center min-h-[70vh] text-center pt-10 pb-20">
        
        <!-- Glitch Headline Effect -->
        <div class="relative inline-block mb-6 group cursor-default">
            <h1 class="font-display text-5xl md:text-7xl font-bold tracking-widest text-[#e0e0e0] uppercase drop-shadow-[0_0_15px_rgba(0,240,255,0.3)] relative z-10 transition-transform duration-500 group-hover:scale-[1.02]">
                Welcome To The <span class="text-neon-cyan drop-shadow-[0_0_10px_rgba(0,240,255,0.8)]">Hub</span>
            </h1>
            <!-- Pseudo Glitch Layers -->
            <h1 class="font-display text-5xl md:text-7xl font-bold tracking-widest text-neon-purple uppercase absolute top-0 left-[2px] -translate-x-1 opacity-0 group-hover:opacity-70 group-hover:animate-pulse -z-10 mix-blend-screen pointer-events-none">
                Welcome To The Hub
            </h1>
            <h1 class="font-display text-5xl md:text-7xl font-bold tracking-widest text-neon-cyan uppercase absolute top-0 left-[-2px] translate-x-1 opacity-0 group-hover:opacity-70 group-hover:animate-pulse -z-10 mix-blend-screen pointer-events-none" style="animation-delay: 100ms;">
                Welcome To The Hub
            </h1>
        </div>

        <p class="font-body text-xl md:text-2xl text-gray-400 max-w-2xl mb-16 leading-relaxed">
            Enter the architecture. A cyber-grecian nexus for agentic experimentation, decentralized philosophy, and AI literacy.
        </p>

        <!-- District Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full max-w-5xl">
            {districts.map(district => (
                <a href={district.href} class={`group relative p-8 border border-white/10 bg-[#0a0a0a]/80 backdrop-blur-xl rounded-xl overflow-hidden transition-all duration-700 hover:-translate-y-2 ${district.shadow} ${district.color}`}>
                    <!-- Hover Glow Background -->
                    <div class="absolute inset-0 bg-gradient-to-br from-white/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none mix-blend-overlay"></div>
                    
                    <div class="relative z-10 flex flex-col items-start text-left h-full">
                        <span class="text-4xl mb-6 grayscale group-hover:grayscale-0 transition-all duration-700 drop-shadow-md">{district.icon}</span>
                        <h2 class="font-display text-2xl font-bold tracking-widest mb-3 text-[#e0e0e0] group-hover:text-inherit transition-colors duration-500">
                            {district.title}
                        </h2>
                        <p class="font-body text-gray-400 group-hover:text-gray-200 transition-colors duration-500 leading-relaxed">
                            {district.desc}
                        </p>
                        
                        <div class="mt-auto pt-8 flex items-center font-display text-[10px] tracking-[0.2em] font-bold uppercase opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500">
                            Enter District <span class="ml-2 group-hover:translate-x-2 transition-transform duration-500">→</span>
                        </div>
                    </div>
                    
                    <!-- Corner Accents -->
                    <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-white/10 group-hover:border-inherit transition-colors duration-500 rounded-tl-lg"></div>
                    <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-white/10 group-hover:border-inherit transition-colors duration-500 rounded-br-lg"></div>
                </a>
            ))}
        </div>
    </div>
</Layout>
